# Salin file ini ke `.env` lalu isi nilainya. JANGAN commit `.env` (berisi rahasia).

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
# Lokal: DATABASE_URL & DIRECT_URL sama.
#
# Supabase (aplikasi ini pakai driver adapter node-postgres, BUKAN konektor
# Prisma bawaan — jadi JANGAN tambahkan ?pgbouncer=true, itu tak berlaku):
#   DATABASE_URL = Transaction Pooler (host ...pooler..., port 6543) — untuk runtime.
#   DIRECT_URL   = Direct connection (port 5432)                     — untuk migrasi.
#   Contoh: postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#   Tambahkan &sslmode=require bila perlu. SSL sudah diaktifkan otomatis untuk host non-lokal.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/toko_komputer?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/toko_komputer?schema=public"

# Opsional: batas koneksi pool per-instance (node-postgres). Default: 5 di
# produksi, 10 di dev. Untuk serverless + Supabase pooler, 3–5 aman.
# DB_POOL_MAX="5"

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate: npx auth secret
AUTH_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
